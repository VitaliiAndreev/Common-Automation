# Tool versions referenced across CI and local. Single source of
# truth - bumping a version here propagates to every consumer in one
# commit. Sourced as bash by:
#
#   - scripts/run-tests.sh                  (local Docker fallback)
#   - .github/actions/bats/action.yml       (resolve-version step)
#
# Format: shell-compatible KEY=value. Quoting unnecessary for plain
# semver strings; if a value ever needs spaces or interpolation,
# quote it.

BATS_VERSION=1.11.0
